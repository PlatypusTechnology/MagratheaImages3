RewriteEngine On

# remove for enabling folder indexes:
Options -Indexes

<Files ".user.ini">
  Require all denied
</Files>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
 
	# uncomment for enabling folder navigation
	# RewriteCond %{REQUEST_FILENAME} -d [OR]
	RewriteCond %{REQUEST_FILENAME} -f
	RewriteRule .+ - [L]

  #Respect this rules for redirecting:
  RewriteCond %{QUERY_STRING} ^(.+)$
  RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/(.*)$ index.php?magrathea_control=$1&magrathea_action=$2&magrathea_params=$3&%1 [L]
  RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/(.*)$ index.php?magrathea_control=$1&magrathea_action=$2&magrathea_params=$3 [L]
  RewriteCond %{QUERY_STRING} ^(.+)$
  RewriteRule ^([a-zA-Z0-9_-]+)/(.*)$ index.php?magrathea_control=$1&magrathea_action=$2&%1 [L]
  RewriteRule ^([a-zA-Z0-9_-]+)/(.*)$ index.php?magrathea_control=$1&magrathea_action=$2 [L]
  RewriteCond %{QUERY_STRING} ^(.+)$
  RewriteRule ^(.*)$ index.php?magrathea_control=$1&%1 [L]
  RewriteRule ^(.*)$ index.php?magrathea_control=$1 [L]
  SetEnvIf Authorization .+ HTTP_AUTHORIZATION=$0

</IfModule>

# `php_value` does not work on dreamhost servers!
# php_value upload_max_filesize 40M
# php_value post_max_size 42M
